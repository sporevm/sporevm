#!/usr/bin/env bash
set -euo pipefail

app_domain="${APP_DOMAIN:-http://buildkite.localhost}"
api_domain="${API_DOMAIN:-http://api.buildkite.localhost}"
agent_domain="${AGENT_DOMAIN:-http://agent.buildkite.localhost}"
webhook_domain="${WEBHOOK_DOMAIN:-http://webhook.buildkite.localhost}"
badge_domain="${BADGE_DOMAIN:-http://badge.buildkite.localhost}"
graphql_domain="${GRAPHQL_DOMAIN:-http://graphql.buildkite.localhost/v1}"
dep_ready_polls="${SPOREVM_BUILDKITE_DEP_READY_POLLS:-120}"
probe_timeout="${SPOREVM_BUILDKITE_PROBE_TIMEOUT:-1}"
compose_up_timeout="${SPOREVM_BUILDKITE_COMPOSE_UP_TIMEOUT:-420}"
docker_storage_driver="${SPOREVM_DOCKER_STORAGE_DRIVER:-vfs}"
runtime_tmpfs_size="${SPOREVM_BUILDKITE_RUNTIME_TMPFS_SIZE:-80%}"
dynamodb_pid=""
dockerd_pid=""
docker_ready=0

while (($#)); do
  case "$1" in
    --dep-ready-polls)
      [[ -n "${2-}" ]] || { echo "missing --dep-ready-polls value" >&2; exit 2; }
      dep_ready_polls="$2"
      shift 2
      ;;
    --probe-timeout)
      [[ -n "${2-}" ]] || { echo "missing --probe-timeout value" >&2; exit 2; }
      probe_timeout="$2"
      shift 2
      ;;
    --compose-up-timeout)
      [[ -n "${2-}" ]] || { echo "missing --compose-up-timeout value" >&2; exit 2; }
      compose_up_timeout="$2"
      shift 2
      ;;
    --docker-storage-driver)
      [[ -n "${2-}" ]] || { echo "missing --docker-storage-driver value" >&2; exit 2; }
      docker_storage_driver="$2"
      shift 2
      ;;
    -h|--help)
      echo "usage: setup-spore [--dep-ready-polls N] [--probe-timeout N] [--compose-up-timeout N] [--docker-storage-driver NAME]"
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

for value_name in dep_ready_polls probe_timeout compose_up_timeout; do
  value="${!value_name}"
  case "${value}" in
    ''|*[!0-9]*|0) echo "--${value_name//_/-} must be a positive integer" >&2; exit 2 ;;
  esac
done

export HOME=/tmp/sporevm-home
export LANG=C.UTF-8
export PATH=/usr/local/bundle/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export RAILS_ENV=test
export DISABLE_SPRING=1
export BUILDKITE_CLEANROOM=1
export SPOREVM_BUILDKITE_RUNTIME_ROOT=/tmp/sporevm-buildkite
export BUNDLE_PATH="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/bundle"
export BUNDLE_APP_CONFIG="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/bundle-config"
export BUNDLE_USER_HOME="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/bundle-home"
export BUNDLE_SILENCE_ROOT_WARNING=1
export SPOREVM_BUILDKITE_SKIP_CLICKHOUSE="${SPOREVM_BUILDKITE_SKIP_CLICKHOUSE:-1}"
export DOCKER_HOST="unix://${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker/docker.sock"
export COMPOSE_PROJECT_NAME=sporevm-buildkite
export COMPOSE_FILE=/usr/local/share/sporevm-buildkite/compose.yaml
export PGHOST=127.0.0.1
export PGHOSTADDR=127.0.0.1
export PGPORT=5433
export PGUSER=postgres
export REDIS_CACHE_URL=redis://127.0.0.1:6379/10
export ACTIONCABLE_REDIS_URL=redis://127.0.0.1:6379/11
export PRIMARY_REDIS_URL=redis://127.0.0.1:6379/0
export PRIMARY_SIDEKIQ_REDIS_URL=redis://127.0.0.1:6379/1
export TEST_ANALYTICS_SIDEKIQ_REDIS_URL=redis://127.0.0.1:6379/2
export PIPELINES_SIDEKIQ_SET_001_REDIS_URL=redis://127.0.0.1:6379/3
export PIPELINES_SIDEKIQ_SET_002_REDIS_URL=redis://127.0.0.1:6379/3
export PIPELINES_SIDEKIQ_SET_003_REDIS_URL=redis://127.0.0.1:6379/3
export RATE_LIMITER_REDIS_URL=redis://127.0.0.1:7000
export SIDEKIQ_LIMITER_REDIS_URL=redis-cluster://127.0.0.1:7000
export LOCKER_REDIS_URL=redis://127.0.0.1:7000
export PIPELINES_REDIS_URL=redis://127.0.0.1:7000
export PIPELINES_CLUSTER_METRICS_REDIS_URL=redis://127.0.0.1:7000
export MEMCACHE_SERVERS=127.0.0.1:11211
export AWS_EC2_METADATA_DISABLED=true
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_REGION=us-east-1
export CLICKHOUSE_URL=http://127.0.0.1:8123
export LOCAL_DYNAMODB_ENDPOINT=http://127.0.0.1:4100
export LOCAL_KMS_ENDPOINT=http://127.0.0.1:8080
export LOCALSTACK_ENDPOINT=http://127.0.0.1:4566
export KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
export PIPELINES_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9094
export PIPELINES_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
export SCHEMA_REGISTRY_URL=http://127.0.0.1:8082
export SCHEMA_REGISTRY_USERNAME=schema
export SCHEMA_REGISTRY_PASSWORD=password
export SMOKESCREEN_PROXY=
export SIGNUP_ENABLED=true
export ORG_CREATION_ENABLED=true
export APP_DOMAIN="${app_domain}"
export API_DOMAIN="${api_domain}"
export AGENT_DOMAIN="${agent_domain}"
export WEBHOOK_DOMAIN="${webhook_domain}"
export BADGE_DOMAIN="${badge_domain}"
export GRAPHQL_DOMAIN="${graphql_domain}"
export HOSTED_MODELS_ANTHROPIC_API_KEY="${HOSTED_MODELS_ANTHROPIC_API_KEY:-test-hosted-models-anthropic-key}"
export HOSTED_MODELS_OPENAI_API_KEY="${HOSTED_MODELS_OPENAI_API_KEY:-test-hosted-models-openai-key}"
export CAPYBARA_APP_HOST=http://127.0.0.1
export SPOREVM_DOCKER_STORAGE_DRIVER="${docker_storage_driver}"
export SPOREVM_BUILDKITE_DEP_READY_POLLS="${dep_ready_polls}"
export SPOREVM_BUILDKITE_PROBE_TIMEOUT="${probe_timeout}"
export SPOREVM_BUILDKITE_COMPOSE_UP_TIMEOUT="${compose_up_timeout}"
export SPOREVM_BUILDKITE_RUNTIME_TMPFS_SIZE="${runtime_tmpfs_size}"

elapsed_since() {
  printf '%s' "$((SECONDS - $1))"
}

cleanup() {
  if [[ "${docker_ready}" == "1" ]]; then
    docker compose -f "${COMPOSE_FILE}" down -v >/dev/null 2>&1 || true
  fi
  if [[ -n "${dynamodb_pid}" ]]; then
    kill -TERM "${dynamodb_pid}" >/dev/null 2>&1 || true
    wait "${dynamodb_pid}" >/dev/null 2>&1 || true
  fi
  if [[ -n "${dockerd_pid}" ]]; then
    kill -TERM "${dockerd_pid}" >/dev/null 2>&1 || true
    wait "${dockerd_pid}" >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT

mount_cgroups() {
  if ! grep -qw cgroup2 /proc/self/mountinfo; then
    mkdir -p "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/cgroup"
    mount -t cgroup2 cgroup2 "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/cgroup" >/dev/null 2>&1 || true
  fi
  if ! grep -q " - cgroup cgroup .*devices" /proc/self/mountinfo; then
    mkdir -p "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/cgroup-devices"
    mount -t cgroup -o devices cgroup "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/cgroup-devices" >/dev/null 2>&1 || true
  fi
}

mount_runtime_tmpfs() {
  mkdir -p "${SPOREVM_BUILDKITE_RUNTIME_ROOT}"
  if ! awk -v mount_point="${SPOREVM_BUILDKITE_RUNTIME_ROOT}" '$5 == mount_point { found = 1 } END { exit(found ? 0 : 1) }' /proc/self/mountinfo; then
    mount -t tmpfs -o "mode=755,size=${SPOREVM_BUILDKITE_RUNTIME_TMPFS_SIZE}" tmpfs "${SPOREVM_BUILDKITE_RUNTIME_ROOT}"
  fi
}

set_dotenv() {
  local file="$1"
  local key="$2"
  local value="$3"

  if grep -q "^${key}=" "${file}"; then
    sed -i "s|^${key}=.*|${key}=${value}|" "${file}"
  else
    printf '%s=%s\n' "${key}" "${value}" >>"${file}"
  fi
}

patch_buildkite_setup() {
  local helpers="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/setup_helpers.rb"
  local setup_clickhouse="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/setup-clickhouse"
  local analytics_seed="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/analytics-seed.rb"

  ruby -e '
    source, dest = ARGV
    text = File.read(source)
    text.sub!(/CLEANROOM_PERSISTENT_SERVICES = %w\[.*?\]\.freeze/m, "CLEANROOM_PERSISTENT_SERVICES = %w[\n  minio\n  postgres\n  valkey\n  memcached\n].freeze")
    text.sub!(/^def ensure_docker_network!\n.*?^end\n/m, "def ensure_docker_network!\nend\n")
    text.sub!(/^def migrate_karafka_topics!\n.*?^end\n/m, "def migrate_karafka_topics!\n  puts \"Skipping Karafka topic migration inside SporeVM\"\nend\n")
    replacement = "def stop_cleanroom_persistent_services!\n  puts \"Keeping cleanroom services running inside SporeVM\"\nend\n"
    abort "stop_cleanroom_persistent_services! not found" unless text.sub!(/^def stop_cleanroom_persistent_services!\n.*?^end\n/m, replacement)
    File.write(dest, text)
  ' /app/bin/lib/setup_helpers.rb "${helpers}"
  mount --bind "${helpers}" /app/bin/lib/setup_helpers.rb

  cat >"${setup_clickhouse}" <<'SH'
#!/usr/bin/env bash
set -euo pipefail

if ! nc -z -w 1 127.0.0.1 8123 >/dev/null 2>&1; then
  echo "Skipping ClickHouse setup; this minimal SporeVM rootfs does not start ClickHouse"
  exit 0
fi
SH
  chmod +x "${setup_clickhouse}"
  mount --bind "${setup_clickhouse}" /app/bin/setup-clickhouse

  ruby -e '
    source, dest = ARGV
    text = File.read(source)
    replacement = <<~RUBY
      def clickhouse_enabled?
        return false if ENV["SPOREVM_BUILDKITE_SKIP_CLICKHOUSE"] == "1"

        Rails.application.config.clickhouse_enabled && Rails.env.development?
      end
    RUBY
    abort "clickhouse_enabled? not found" unless text.sub!(/^def clickhouse_enabled\?\n.*?^end\n/m, replacement)
    File.write(dest, text)
  ' /app/db/seeds/analytics.rb "${analytics_seed}"
  mount --bind "${analytics_seed}" /app/db/seeds/analytics.rb
}

mount_guest_runtime_dirs() {
  mkdir -p "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/etc"
  cp -a /etc/. "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/etc/"
  {
    printf '127.0.0.1 localhost buildkite.localhost buildkite.test\n'
    printf '::1 localhost\n'
  } >"${SPOREVM_BUILDKITE_RUNTIME_ROOT}/etc/hosts"
  mount --bind "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/etc" /etc
  mount -t tmpfs tmpfs /app/log >/dev/null 2>&1 || true
  mount -t tmpfs tmpfs /app/tmp >/dev/null 2>&1 || true

  local dotenv_sample="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/.env-sample"
  cp /app/.env-sample "${dotenv_sample}"
  set_dotenv "${dotenv_sample}" MINIO_DOMAIN 127.0.0.1:3300
  set_dotenv "${dotenv_sample}" NEW_ARTIFACT_HOST http://127.0.0.1:3300/test-buildkite-artifacts
  set_dotenv "${dotenv_sample}" NEW_ARTIFACT_S3_HOST http://127.0.0.1:3300
  set_dotenv "${dotenv_sample}" NEW_ARTIFACT_S3_BUCKET test-buildkite-artifacts
  set_dotenv "${dotenv_sample}" ASSET_UPLOADS_S3_BUCKET test-buildkiteusercontent/assets
  set_dotenv "${dotenv_sample}" JOB_LOGS_S3_BUCKET test-buildkite-cloud-dev
  set_dotenv "${dotenv_sample}" BUILD_EXPORTS_S3_BUCKET test-buildkite-build-exports
  set_dotenv "${dotenv_sample}" DATA_PLATFORM_S3_BUCKET test-buildkite-data-platform-ingestion
  set_dotenv "${dotenv_sample}" GRAVEYARD_S3_BUCKET test-buildkite-graveyard
  set_dotenv "${dotenv_sample}" BUILDKITE_PIPELINES_SECRETS_ORGANIZATION_KEY_BUCKET test-buildkite-pipelines-secrets-organization-keys
  set_dotenv "${dotenv_sample}" BUILDKITE_PIPELINES_SECRETS_CLUSTER_KEY_BUCKET test-buildkite-pipelines-secrets-cluster-keys
  set_dotenv "${dotenv_sample}" BUILDKITE_PIPELINES_SECRETS_SECRET_VERSION_MATERIAL_BUCKET test-buildkite-pipelines-secrets-secret-version-material
  set_dotenv "${dotenv_sample}" BUILDKITE_TA_UPLOADS_S3_BUCKET test-buildkite-ta-uploads
  set_dotenv "${dotenv_sample}" PACKAGES_OFFICIAL_REGISTRY_PACKAGE_FILE_BUCKET test-buildkite-official-package-files
  set_dotenv "${dotenv_sample}" PACKAGES_BLOBS_S3_BUCKET test-buildkite-packages-blobs
  set_dotenv "${dotenv_sample}" ANALYTICS_EXECUTIONS_S3_BUCKET test-buildkite-ta-executions
  set_dotenv "${dotenv_sample}" ANALYTICS_RUNS_S3_BUCKET test-buildkite-ta-run-uploads
  set_dotenv "${dotenv_sample}" ANALYTICS_TRACE_SPANS_S3_BUCKET test-buildkite-ta-trace-spans
  set_dotenv "${dotenv_sample}" TEST_ENGINE_COMMIT_METADATA_S3_BUCKET test-buildkite-te-commit-metadata
  set_dotenv "${dotenv_sample}" EVENT_LOG_API_S3_BUCKET test-buildkite-event-log-api
  set_dotenv "${dotenv_sample}" WEBHOOK_UPLOAD_S3_BUCKET test-buildkite-inbound-webhooks
  set_dotenv "${dotenv_sample}" LOCAL_DYNAMODB_ENDPOINT "${LOCAL_DYNAMODB_ENDPOINT}"
  set_dotenv "${dotenv_sample}" LOCAL_KMS_ENDPOINT "${LOCAL_KMS_ENDPOINT}"
  mount --bind "${dotenv_sample}" /app/.env-sample
  patch_buildkite_setup
}

check_file_locking() {
  ruby -e 'File.open("/tmp/sporevm-flock-check", "w") { |f| exit(f.flock(File::LOCK_EX | File::LOCK_NB) ? 0 : 1) }' >/dev/null 2>&1 || {
    echo "Docker Engine requires flock(2); run with a SporeVM kernel that has CONFIG_FILE_LOCKING=y." >&2
    exit 1
  }
}

start_dockerd() {
  local phase_start="${SECONDS}"
  mkdir -p \
    "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker" \
    "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker-data" \
    "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker-exec" \
    "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/logs" \
    "${HOME}"
  rm -f "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker/docker.sock" "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker.pid"
  mount_cgroups

  dockerd \
    --host "${DOCKER_HOST}" \
    --data-root "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker-data" \
    --exec-root "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker-exec" \
    --pidfile "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/docker.pid" \
    --storage-driver "${SPOREVM_DOCKER_STORAGE_DRIVER}" \
    --iptables=false \
    --bridge=none \
    --ip-forward=false \
    --ip-masq=false \
    >"${SPOREVM_BUILDKITE_RUNTIME_ROOT}/logs/dockerd.log" 2>&1 &
  dockerd_pid="$!"

  for _ in $(seq 1 "${SPOREVM_DOCKER_READY_POLLS:-90}"); do
    if docker info >/dev/null 2>&1; then
      docker_ready=1
      printf 'SPOREVM_DOCKER_READY elapsed=%ss\n' "$(elapsed_since "${phase_start}")"
      return 0
    fi
    if ! kill -0 "${dockerd_pid}" >/dev/null 2>&1; then
      cat "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/logs/dockerd.log" >&2 || true
      echo "dockerd exited before becoming ready" >&2
      exit 1
    fi
    sleep 1
  done
  cat "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/logs/dockerd.log" >&2 || true
  echo "dockerd did not become ready" >&2
  exit 1
}

load_dependency_images() {
  local archive
  shopt -s nullglob
  for archive in /opt/sporevm-buildkite-deps/*.tar; do
    echo "loading ${archive##*/}" >&2
    docker load -i "${archive}" >/dev/null
  done
  shopt -u nullglob
  docker image inspect \
    buildkite-postgres:latest \
    valkey/valkey:8.1-alpine \
    memcached:1.6-alpine \
    minio/minio:RELEASE.2025-04-22T22-12-26Z \
    nsmithuk/local-kms:3.11.7 >/dev/null
}

start_dynamodb_local() {
  local data_dir="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/dynamodb"
  mkdir -p "${data_dir}"
  java -Xmx128m \
    -Djava.library.path=/opt/sporevm-buildkite-dynamodb/DynamoDBLocal_lib \
    -jar /opt/sporevm-buildkite-dynamodb/DynamoDBLocal.jar \
    -port 4100 \
    -disableTelemetry \
    -dbPath "${data_dir}" \
    >"${SPOREVM_BUILDKITE_RUNTIME_ROOT}/logs/dynamodb.log" 2>&1 &
  dynamodb_pid="$!"
}

dump_dependency_diagnostics() {
  docker ps --no-trunc >&2 || true
  docker compose -f "${COMPOSE_FILE}" ps >&2 || true
  docker compose -f "${COMPOSE_FILE}" logs --tail=200 >&2 || true
  tail -200 "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/logs/dockerd.log" >&2 || true
  tail -200 "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/logs/dynamodb.log" >&2 || true
}

probe_failed=()

check_probe() {
  local name="$1"
  shift
  timeout --kill-after=1s "${SPOREVM_BUILDKITE_PROBE_TIMEOUT}" "$@" >/dev/null 2>&1 || probe_failed+=("${name}")
}

check_probe_shell() {
  local name="$1"
  local command="$2"
  timeout --kill-after=1s "${SPOREVM_BUILDKITE_PROBE_TIMEOUT}" bash -c "${command}" >/dev/null 2>&1 || probe_failed+=("${name}")
}

wait_for_dependencies() {
  local missing last_missing=""
  for _ in $(seq 1 "${SPOREVM_BUILDKITE_DEP_READY_POLLS}"); do
    probe_failed=()
    check_probe postgres pg_isready -h 127.0.0.1 -p 5433 -U postgres
    check_probe redis-cache redis-cli -h 127.0.0.1 -p 6379 ping
    check_probe redis-test-isolation redis-cli -h 127.0.0.1 -p 6380 -n 10 ping
    check_probe_shell redis-cluster "redis-cli -h 127.0.0.1 -p 7000 cluster info 2>/dev/null | grep -q 'cluster_state:ok'"
    check_probe memcached nc -z -w 1 127.0.0.1 11211
    check_probe minio nc -z -w 1 127.0.0.1 3300
    check_probe dynamodb nc -z -w 1 127.0.0.1 4100
    check_probe kms nc -z -w 1 127.0.0.1 8080
    ((${#probe_failed[@]} == 0)) && return 0
    missing="${probe_failed[*]}"
    if [[ "${missing}" != "${last_missing}" ]]; then
      printf 'SPOREVM_BUILDKITE_WAIT missing=%s\n' "${missing}" >&2
      last_missing="${missing}"
    fi
    sleep 1
  done
  dump_dependency_diagnostics
  echo "Buildkite dependencies did not become ready" >&2
  exit 1
}

prepare_docker_shim() {
  local bin_dir="${SPOREVM_BUILDKITE_RUNTIME_ROOT}/fake-bin"
  mkdir -p "${bin_dir}"
  cat >"${bin_dir}/docker" <<'SH'
#!/bin/sh
if [ "$1" = "compose" ] && [ "$2" = "ps" ] && [ "$3" = "-q" ] && [ "$4" = "dynamodb" ]; then
  echo sporevm-dynamodb
  exit 0
fi
exec /usr/bin/docker "$@"
SH
  chmod +x "${bin_dir}/docker"
  export PATH="${bin_dir}:${PATH}"
}

write_env() {
  mkdir -p "${BUNDLE_PATH}" "${BUNDLE_APP_CONFIG}" "${BUNDLE_USER_HOME}"
  export -p >"${SPOREVM_BUILDKITE_RUNTIME_ROOT}/env.sh"
  chmod 0644 "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/env.sh"
}

mount_runtime_tmpfs
mount_guest_runtime_dirs
check_file_locking
start_dockerd
load_dependency_images
start_dynamodb_local

if ! timeout --kill-after=10s "${SPOREVM_BUILDKITE_COMPOSE_UP_TIMEOUT}" docker compose -f "${COMPOSE_FILE}" up -d; then
  dump_dependency_diagnostics
  echo "docker compose up did not complete" >&2
  exit 1
fi
wait_for_dependencies
prepare_docker_shim
write_env
touch "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/ready"
printf 'SPOREVM_BUILDKITE_READY env=%s\n' "${SPOREVM_BUILDKITE_RUNTIME_ROOT}/env.sh"

while sleep 3600; do :; done
