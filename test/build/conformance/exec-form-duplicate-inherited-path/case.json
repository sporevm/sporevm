{
  "description": "exec-form RUN normalizes duplicate PATH within a stage and reconstructs it from published config across FROM",
  "expect": {
    "docker": "success",
    "spore": "success"
  },
  "initial_cache": "miss",
  "initial_execution": {
    "expect_executed_steps": 4,
    "expect_boot_count": 2,
    "expect_resize_count": 1
  },
  "base_env": [
    "PATH=/oracle/duplicate-env/a",
    "PATH=/oracle/duplicate-env/b:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin"
  ],
  "scan_prefixes": [
    "/oracle/duplicate-env/result"
  ],
  "transitions": [
    {
      "name": "warm",
      "expect_cache": "hit",
      "expect_index": "same",
      "expect_executed_steps": 0,
      "expect_boot_count": 0,
      "expect_resize_count": 0
    }
  ]
}
