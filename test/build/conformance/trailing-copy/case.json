{
  "description": "a final COPY invalidates independently and then becomes warm",
  "expect": {
    "docker": "success",
    "spore": "success"
  },
  "initial_cache": "miss",
  "initial_execution": {
    "expect_executed_steps": 3,
    "expect_boot_count": 1,
    "expect_resize_count": 1
  },
  "scan_prefixes": [
    "/oracle"
  ],
  "transitions": [
    {
      "name": "warm",
      "expect_cache": "hit",
      "expect_index": "same",
      "expect_executed_steps": 0,
      "expect_boot_count": 0,
      "expect_resize_count": 0
    },
    {
      "name": "payload-change",
      "writes": {
        "payload.txt": "other\n"
      },
      "expect_cache": "miss",
      "expect_index": "changed",
      "expect_executed_steps": 1,
      "expect_boot_count": 1,
      "expect_resize_count": 0,
      "compare": true
    },
    {
      "name": "warm-after-change",
      "expect_cache": "hit",
      "expect_index": "same",
      "expect_executed_steps": 0,
      "expect_boot_count": 0,
      "expect_resize_count": 0
    }
  ]
}
