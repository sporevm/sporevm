{
  "description": "default read-only context-file binds compose with absent SSH and cache mounts without entering rootfs snapshots",
  "expect": {
    "docker": "success",
    "spore": "success"
  },
  "initial_cache": "miss",
  "initial_execution": {
    "expect_executed_steps": 4,
    "expect_boot_count": 1,
    "expect_resize_count": 1
  },
  "scan_prefixes": [
    "/oracle",
    "/work",
    "/var/cache/oracle-bind-a",
    "/var/cache/oracle-bind-b",
    "/run/buildkit"
  ],
  "transitions": [
    {
      "name": "warm",
      "expect_cache": "hit",
      "expect_index": "same",
      "expect_executed_steps": 0,
      "expect_boot_count": 0,
      "expect_resize_count": 0
    },
    {
      "name": "mtime-only-source-change",
      "writes": {
        "Gemfile": "gemfile original\n"
      },
      "expect_cache": "hit",
      "expect_index": "same",
      "expect_executed_steps": 0,
      "expect_boot_count": 0,
      "expect_resize_count": 0,
      "compare": true
    },
    {
      "name": "forced-miss-after-mtime-change",
      "writes": {
        "Gemfile.lock": "gemfile lock changed\n"
      },
      "expect_cache": "miss",
      "expect_index": "changed",
      "expect_executed_steps": 2,
      "expect_boot_count": 1,
      "expect_resize_count": 0,
      "compare": true
    },
    {
      "name": "changed-source-mode",
      "modes": {
        "Gemfile": "0755"
      },
      "expect_cache": "miss",
      "expect_index": "changed",
      "expect_executed_steps": 2,
      "expect_boot_count": 1,
      "expect_resize_count": 0,
      "compare": true
    },
    {
      "name": "changed-source-content",
      "writes": {
        "Gemfile": "gemfile changed\n"
      },
      "expect_cache": "miss",
      "expect_index": "changed",
      "expect_executed_steps": 2,
      "expect_boot_count": 1,
      "expect_resize_count": 0,
      "compare": true
    },
    {
      "name": "warm-after-source-change",
      "expect_cache": "hit",
      "expect_index": "same",
      "expect_executed_steps": 0,
      "expect_boot_count": 0,
      "expect_resize_count": 0
    }
  ]
}
