FROM base
COPY sandbox_probe.py /oracle/sandbox_probe.py
RUN mkdir -p /existing-cache && printf rootfs >/existing-cache/rootfs-value
RUN --mount=type=cache,target=/cache-parent/cache-a sh -euxc 'printf sibling >/cache-parent/cache-a/value; printf rootfs >/cache-parent/rootfs-value'
RUN --mount=type=cache,target=/cache-b --mount=type=cache,target=/existing-cache sh -euxc 'test "$(cat /cache-parent/rootfs-value)" = rootfs; test ! -e /cache-parent/cache-a; test ! -e /existing-cache/rootfs-value; test ! -e /run/sporevm/build-cache; test ! -e /proc/1/root/run/sporevm; test ! -e /dev/vda; test ! -e /dev/vdb; test ! -e /dev/vdc; test ! -e /dev/console; test ! -e /dev/hvc0; test ! -e /dev/vsock; python3 /oracle/sandbox_probe.py; mknod /tmp/spore-cache-block-probe b 254 0; if dd if=/tmp/spore-cache-block-probe of=/dev/null bs=1 count=1 2>/tmp/spore-cache-block-error; then exit 91; fi; grep -q "Operation not permitted" /tmp/spore-cache-block-error; mkdir -p /tmp/spore-cache-mount-probe; if mount -t proc proc /tmp/spore-cache-mount-probe 2>/tmp/spore-cache-mount-error; then exit 92; fi; grep -Eq "Operation not permitted|permission denied" /tmp/spore-cache-mount-error; printf selected >/cache-b/value; printf selected >/existing-cache/cache-value; (sleep 1; printf leaked >/oracle/leaked-descendant) & printf sandboxed >/oracle/result'
RUN --mount=type=cache,target=/cache-parent/cache-a --mount=type=cache,target=/existing-cache sh -euxc 'test "$(cat /cache-parent/cache-a/value)" = sibling; test "$(cat /cache-parent/rootfs-value)" = rootfs; test "$(cat /existing-cache/cache-value)" = selected; test ! -e /existing-cache/rootfs-value; test ! -e /cache-b; test ! -e /run/sporevm/build-cache; test ! -e /proc/1/root/run/sporevm; test ! -e /oracle/leaked-descendant; printf verified >/oracle/cache-result'
RUN sleep 2 && test "$(cat /cache-parent/rootfs-value)" = rootfs && test "$(cat /existing-cache/rootfs-value)" = rootfs && test ! -e /existing-cache/cache-value && test ! -e /cache-parent/cache-a && test ! -e /cache-b && test ! -e /oracle/leaked-descendant && test "$(cat /oracle/result)" = sandboxed && test "$(cat /oracle/cache-result)" = verified
