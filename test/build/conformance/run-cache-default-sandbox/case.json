{
  "description": "cache-mounted RUN exposes only selected cache directories inside the operation sandbox",
  "expect": {
    "docker": "success",
    "spore": "success"
  },
  "initial_cache": "miss",
  "initial_execution": {
    "expect_executed_steps": 6,
    "expect_boot_count": 1,
    "expect_resize_count": 1
  },
  "scan_prefixes": [
    "/oracle",
    "/cache-parent",
    "/cache-b",
    "/existing-cache"
  ],
  "transitions": [
    {
      "name": "warm",
      "expect_cache": "hit",
      "expect_index": "same",
      "expect_executed_steps": 0,
      "expect_boot_count": 0,
      "expect_resize_count": 0
    }
  ]
}
